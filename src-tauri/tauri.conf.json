{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "valeska",
  "version": "9.0.0",
  "identifier": "studios.tkoh.valeska",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sistema Valeska",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "es-ES"
      },
      "nsis": {
        "languages": ["Spanish"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyNzE3NzEwQTY4RDVCMjUKUldRbFc0Mm1FSGR4b3NtbnNLWjJIU1BXUEk2Mzhib09Pa1ZQY081Tm43QnBmK2R0aFp1WWRvMlMK",
      "endpoints": [
        "https://valeska-api.studios-tkoh.online/api/desktop-updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
